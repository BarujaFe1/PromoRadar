# ============================================================
# PromoRadar Telegram — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── Telegram User API ──
# Obtenha em https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_SESSION_NAME=promoradar
TELEGRAM_PHONE=+5511999999999

# ── Grupos monitorados (IDs separados por vírgula, vazio = todos) ──
MONITORED_GROUPS=

# ── Backfill ──
BACKFILL_BATCH_SIZE=100
BACKFILL_DELAY_SEC=2.0

# ── PostgreSQL ──
DB_HOST=postgres
DB_PORT=5432
DB_NAME=promoradar
DB_USER=promoradar
DB_PASSWORD=promoradar

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Parser ──
PARSER_BATCH_SIZE=50
PARSER_INTERVAL_SEC=30
LLM_FALLBACK_ENABLED=false
LLM_API_KEY=

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000

# ── App ──
LOG_LEVEL=INFO
ENVIRONMENT=development
